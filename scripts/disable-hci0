#!/bin/bash
# Disable built-in Qualcomm Bluetooth (hci0), enable TP-Link (hci1)
#
# Using bluetoothctl only (NOT rfkill) — rfkill corrupts bluetoothd's
# state for other adapters. bluetoothctl cleanly powers off hci0
# without affecting hci1.

for i in 1 2 3 4 5; do
  bluetoothctl list 2>/dev/null | grep -q . && break
  sleep 2
done

bluetoothctl << EOF
select XX:XX:XX:XX:XX:XX
power off
select YY:YY:YY:YY:YY:YY
power on
discoverable on
quit
EOF
